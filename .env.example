# Florence Mae Gifts Tracker Server environment
# Copy this file to .env for local development and fill in real values.
# Never commit .env or real secrets.

DB_HOST=your-database-host
DB_PORT=3306
DB_USER=your-database-user
DB_PASSWORD=your-database-password
DB_NAME=your-database-name

LOGIN_PASSWORD=your-login-code
# Must be a long random string, minimum 32 characters.
JWT_SECRET=replace-with-a-long-random-string-at-least-32-characters

FRONTEND_URL=https://your-frontend.example.com
